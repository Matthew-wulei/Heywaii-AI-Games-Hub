// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// User & Authentication (Auth.js Compatible)
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  balance       Int       @default(0) // Platform coins/points
  brandId       String? // Sengoku multi-tenant compatibility
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  games         Game[] // Games authored by user
  characters    Character[] // Characters authored by user
  apiKeys       UserApiKey[]
  playHistories PlayHistory[]
  favorites     Favorite[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

// ==========================================
// Platform Core Data
// ==========================================

model UserApiKey {
  id        String      @id @default(cuid())
  userId    String
  provider  ApiProvider
  key       String      @db.Text // Encrypted
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

enum ApiProvider {
  OPENAI
  ANTHROPIC
  GEMINI
  DEEPSEEK
}

model OfficialApiConfig {
  id        String      @id @default(cuid())
  provider  ApiProvider @unique
  baseUrl   String?
  key       String      @db.Text // Encrypted
  cost      Int         @default(10) // Coins to deduct per request
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

// ==========================================
// Games & Characters Content
// ==========================================

model Game {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  url              String?
  shortDescription String
  fullDescription  String        @db.Text
  coverImage       String
  screenshots      Json?         // String[] stored as JSON array
  categorySlug     String
  status           ContentStatus @default(PENDING)
  source           ContentSource @default(UGC)
  sourceUrl        String?
  externalId       String?       // Original ID from crawler source, for incremental updates

  // Game metadata
  developer        String?       // Developer / team name
  developerUrl     String?       // Developer official website
  releaseDate      DateTime?     // Game release date
  platform         Json?         // String[] e.g. ["Web", "iOS", "Android"]
  language         Json?         // String[] e.g. ["en", "zh", "ja"]
  isFree           Boolean       @default(true)
  pricingNote      String?       // e.g. "Free + In-App Purchase"

  // Stats
  plays       Int   @default(0)
  likes       Int   @default(0)
  rating      Float @default(0)  // Average rating 0-5
  ratingCount Int   @default(0)  // Number of ratings

  // Editorial
  featured      Boolean @default(false)
  featuredOrder Int?    // Lower = higher priority on homepage

  authorId String? // Nullable if from crawler
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags          GameTag[]
  playHistories PlayHistory[]
  favorites     Favorite[]
}

model Character {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  avatar       String
  description  String        @db.Text
  categorySlug String
  status       ContentStatus @default(PENDING)
  source       ContentSource @default(UGC)

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  games GameTag[]
}

model GameTag {
  gameId String
  tagId  String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([gameId, tagId])
}

enum ContentStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

enum ContentSource {
  UGC
  CRAWLER
}

// ==========================================
// User Activities
// ==========================================

model PlayHistory {
  id       String   @id @default(cuid())
  userId   String
  gameId   String
  playedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

// ==========================================
// Blog & Announcements
// ==========================================

model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @db.Text
  coverImage  String?
  category    String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  body        String    @db.Text
  type        String    @default("info")
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CrawlerSource {
  id           String   @id @default(cuid())
  name         String
  entryUrl     String
  itemSelector String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
